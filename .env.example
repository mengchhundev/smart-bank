# ════════════════════════════════════════════════════════════════
# SmartBank – Environment Variables
#
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════

# ── Docker Hub ──────────────────────────────────────────────────
# Your Docker Hub username (images are pushed as {USERNAME}/smartbank-{service})
DOCKERHUB_USERNAME=your-dockerhub-username

# Image tag deployed by docker-compose.prod.yml
# Typically set by the CD pipeline: main-<git-sha>
IMAGE_TAG=latest

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=smartbank
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=smartbank

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── JWT ─────────────────────────────────────────────────────────
# Minimum 256-bit (32-byte) secret, base64-encoded recommended
# Generate: openssl rand -base64 64
JWT_SECRET=change-me-very-long-jwt-secret-minimum-256-bits-required-here
JWT_EXPIRATION_MS=3600000     # 1 hour

# ── Config Server ───────────────────────────────────────────────
CONFIG_SERVER_USER=configuser
CONFIG_SERVER_PASSWORD=change-me-config-password

# Git repository that backs Spring Cloud Config Server (prod profile)
# Can be a private repo with SPRING_CLOUD_CONFIG_SERVER_GIT_PRIVATE_KEY
CONFIG_GIT_URI=https://github.com/your-org/smartbank-config
CONFIG_GIT_BRANCH=main

# ── SMTP (Production Email) ─────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key

# ── Grafana ─────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-grafana-password
GRAFANA_ROOT_URL=https://grafana.yourcompany.com

# ════════════════════════════════════════════════════════════════
# GitHub Secrets – must be configured in your GitHub repository
# Settings → Secrets and variables → Actions → New repository secret
# ════════════════════════════════════════════════════════════════
#
# ── CI secrets ──────────────────────────────────────────────────
# DOCKERHUB_USERNAME      Docker Hub username
# DOCKERHUB_TOKEN         Docker Hub access token (not password)
#                         Create at hub.docker.com → Account Settings → Security
#
# SONAR_TOKEN             SonarCloud user token
#                         sonarcloud.io → My Account → Security → Generate Token
# SONAR_PROJECT_KEY       SonarCloud project key  (e.g. your-org_smart-banking)
# SONAR_ORG               SonarCloud organisation slug
#
# ── CD – Staging secrets ────────────────────────────────────────
# STAGING_HOST            IP or hostname of staging server
# STAGING_USER            SSH user on staging server  (e.g. deploy)
# STAGING_SSH_KEY         Private SSH key (PEM) for staging server
#                         The matching public key must be in ~/.ssh/authorized_keys
#
# ── CD – Production secrets ─────────────────────────────────────
# PROD_HOST               IP or hostname of production server
# PROD_USER               SSH user on production server
# PROD_SSH_KEY            Private SSH key (PEM) for production server
#
# ── Shared runtime secrets (set in GitHub Environment secrets) ──
# These are passed through the CD pipeline to docker-compose.prod.yml:
#
# POSTGRES_PASSWORD       (set in both staging + production GitHub Environments)
# REDIS_PASSWORD
# JWT_SECRET
# CONFIG_SERVER_PASSWORD
# SMTP_PASSWORD
# GRAFANA_PASSWORD
#
# ════════════════════════════════════════════════════════════════
# GitHub Environments to create (Settings → Environments)
# ════════════════════════════════════════════════════════════════
#
# Name: staging
#   - No protection rules needed (auto-deploy on CI pass)
#   - Environment secrets: STAGING_HOST, STAGING_USER, STAGING_SSH_KEY,
#     POSTGRES_PASSWORD, REDIS_PASSWORD, JWT_SECRET, CONFIG_SERVER_PASSWORD,
#     SMTP_PASSWORD, GRAFANA_PASSWORD
#
# Name: production
#   - Required reviewers: add at least one team member
#   - Deployment branches: main only
#   - Environment secrets: PROD_HOST, PROD_USER, PROD_SSH_KEY,
#     POSTGRES_PASSWORD, REDIS_PASSWORD, JWT_SECRET, CONFIG_SERVER_PASSWORD,
#     SMTP_PASSWORD, GRAFANA_PASSWORD
